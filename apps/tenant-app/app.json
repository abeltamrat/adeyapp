{
  "expo": {
    "name": "AdeyApp Tenant",
    "slug": "adeyapp-tenant",
    "scheme": "adeyapp-tenant",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "install": {
      "exclude": ["react-native-safe-area-context", "react-native-screens", "@react-navigation/native", "expo-status-bar"]
    },
    "android": {
      "package": "com.adeyapp.tenant"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "baseUrl": "/app"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e37ccef6-0b87-4d16-bfdc-f327359df626"
      }
    },
    "owner": "abeltamrat"
  }
}
