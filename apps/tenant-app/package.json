{
  "name": "@adeyapp/tenant-app",
  "private": true,
  "version": "0.1.0",
  "main": "expo-router/entry",
  "expo": {
    "install": {
      "exclude": [
        "@react-navigation/native",
        "expo-status-bar",
        "react-native-safe-area-context",
        "react-native-screens"
      ]
    }
  },
  "dependencies": {
    "@adeyapp/api-client": "workspace:*",
    "@adeyapp/auth": "workspace:*",
    "@adeyapp/types": "workspace:*",
    "@react-navigation/native": "7.0.14",
    "@babel/runtime": "^7.29.2",
    "@expo/metro-runtime": "^4.0.0",
    "expo": "^52.0.7",
    "expo-constants": "~17.0.3",
    "expo-linking": "~7.0.3",
    "expo-font": "~13.0.1",
    "expo-file-system": "~18.0.12",
    "expo-router": "^4.0.7",
    "expo-status-bar": "~2.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "^0.76.2",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "scripts": {
    "android:bundle": "pnpm exec expo export:embed --eager --platform android --dev false",
    "build": "pnpm exec expo export --platform web",
    "dev": "pnpm exec expo start",
    "doctor": "npx expo-doctor",
    "lint": "node -e \"console.log('lint placeholder: tenant-app')\"",
    "test": "node -e \"console.log('test placeholder: tenant-app')\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
